<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      metal:use-macro="context/main_template/macros/master"
      lang="en"
      i18n:domain="genweb6.organs">

<body>

<metal:column_one fill-slot="column_one_slot" />
<metal:content-core fill-slot="main">

<tal:print tal:define="portal_state context/@@plone_portal_state; 
                       portal_url portal_state/portal_url;">

  <tal:block i18n:domain="genweb6.organs" tal:condition="view/canView"
           tal:define="getActaLogo view/getActaLogo;
                      signatura view/signatura;
                      Title context/Title;
                      modalitat view/sessionModality;
                      llocConvocatoria context/llocConvocatoria;
                      horaInici context/horaInici;
                      horaFi context/horaFi;
                      membresConvocats context/membresConvocats;
                      membresConvidats context/membresConvidats;
                      llistaExcusats context/llistaExcusats;
                      assistents context/assistents;
                      llistaNoAssistens context/llistaNoAssistens;
                      ordenDelDia context/ordenDelDia;
                      acta view/getActaContent">

    <div class="row mb-4">
      <tal:condition tal:condition="getActaLogo">
        <div class="col-6">
          <img style="height:67px;" tal:attributes="src getActaLogo" />
        </div>
        <div class="col-6" class="text-end">
          <img width="207px" height="46px" tal:attributes="src string:${portal_url}/++theme++genweb6.organs/img/logoUPC.png"/>
        </div>
      </tal:condition>
      <tal:condition tal:condition="not:getActaLogo">
        <div class="col-12">
          <img width="207px" height="46px" tal:attributes="src string:${portal_url}/++theme++genweb6.organs/img/logoUPC.png"/>
        </div>
      </tal:condition>
    </div>

    <div class="clearfix"></div>
    <h1 class="h6"><tal:omit-tag tal:content="view/unitatTitle">UNITAT</tal:omit-tag> — <tal:omit-tag tal:content="view/organGovernTitle">CONSELL DE GOVERN</tal:omit-tag></h1>
    <h2 class="h6">ACTA <tal:omit-tag tal:content="view/sessionTitle">CONSELL DE GOVERN</tal:omit-tag></h2>
    <span i18n:translate=""> Amb la signatura d'aquesta acta es dóna validesa i integritat als documents que l'acompanyen. </span>
    <hr/>
    <div class="col-12 pt-2 pb-1">
      <p tal:condition="modalitat">
        <strong i18n:translate="">Modality of meet</strong><b>:</b>
        <span i18n:translate="" tal:content="modalitat"></span>
      </p>
      <p tal:condition="llocConvocatoria">
        <strong i18n:translate="">Session location</strong><b>:</b>
        <span tal:content="llocConvocatoria"></span>
      </p>
      <p tal:condition="horaInici">
        <strong i18n:translate="">Dia/Hora inici</strong><b>:</b>
        <span tal:content="python:context.horaInici.strftime('%d/%m/%Y %H:%M')"></span>
      </p>
      <p tal:condition="horaFi">
        <strong i18n:translate="">Dia/Hora fi</strong><b>:</b>
        <span tal:content="python:context.horaFi.strftime('%d/%m/%Y %H:%M')"></span>
      </p>
    </div>
    <div class="clearfix"></div>
    <hr/>
    <div class="col-12">
      <div class="caixa col-12" tal:condition="membresConvocats">
        <h3 class="h6" i18n:translate="">Assistants</h3>
        <div tal:replace="structure membresConvocats/output"></div>
      </div>
      <div class="caixa col-12">
        <p tal:condition="membresConvidats">
          <h3 class="h6" i18n:translate="">Invited members</h3>
          <span tal:replace="structure membresConvidats/output"></span>
        </p>
        <p tal:condition="llistaExcusats">
          <h3 class="h6" i18n:translate="">Excused members</h3>
          <span tal:replace="structure llistaExcusats/output"></span>
        </p>
        <p tal:condition="llistaNoAssistens">
          <h3 class="h6" i18n:translate="">Missing members</h3>
          <span tal:replace="structure llistaNoAssistens/output"></span>
        </p>
      </div>
    </div>
    <div class="clearfix"></div>
    <hr/>
    <div tal:condition="acta">
      <h3 class="h6" i18n:translate="">Ordre del dia</h3>
      <span tal:replace="structure acta"></span>
    </div>
    <div class="clearfix"></div>
    <hr/>
    <div tal:condition="ordenDelDia">
      <h3 class="h6" i18n:translate="">Desenvolupament de la sessio</h3>
      <span tal:replace="structure ordenDelDia/output"></span>
    </div>
    <tal:block tal:condition="signatura">
      <br/>
      <span tal:replace="structure signatura"></span>
    </tal:block>
  </tal:block>

</tal:print>

</metal:content-core>

</body>
</html>